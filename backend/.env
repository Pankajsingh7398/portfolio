# Environment Variables — Portfolio Backend
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB (Local)
MONGO_URI=mongodb://127.0.0.1:27017/portfolio

# MongoDB Atlas (Production — replace with your Atlas connection string)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# CORS — allowed frontend origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500
